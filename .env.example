# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/eventora
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_database_password_here

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_here_min_32_chars

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_gmail_app_specific_password
MAIL_FROM=noreply@yourcompany.com

# Frontend URL
FRONTEND_URL=http://localhost:3000
